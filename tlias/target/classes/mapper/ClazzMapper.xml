<!--定义Mapper映射文件的约束和基本结构-->
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.qi.mapper.ClazzMapper">
    <select id="findAll" resultType="com.qi.pojo.Clazz">
        select c.*,e.name masterName
        from clazz c left join emp e on c.master_id=e.id
        <where>
            <if test="name != null and name!=''">
                c.name like concat('%',#{name},'%')
            </if>

            <if test="begin!=null and end!=null">
                and c.end_date between #{begin} and #{end}
            </if>
        </where>
    </select>
    <!--    添加班级-->
    <insert id="insert" parameterType="com.qi.pojo.Clazz">
        insert into clazz(name, room, begin_date, end_date, master_id, subject, create_time, update_time)
        values (#{name}, #{room}, #{beginDate}, #{endDate}, #{masterId}, #{subject}, #{createTime}, #{updateTime})
    </insert>
    <!--    根据id查询回显-->
    <select id="findById" resultType="com.qi.pojo.Clazz">
        select*
        from clazz
        where id = #{id}
    </select>
    <!--    修改班级-->
    <update id="update">
        update clazz
        <set>
            <if test="name != null and name != ''">
                name = #{name},
            </if>
            <if test="room != null and room != ''">
                room = #{room},
            </if>
            <if test="beginDate != null">
                begin_date = #{beginDate},
            </if>
            <if test="endDate != null">
                end_date = #{endDate},
            </if>
            <if test="masterId != null">
                master_id = #{masterId},
            </if>
            <if test="subject != null">
                subject = #{subject},
            </if>
            <!-- 自动更新修改时间 -->
            update_time = now()
        </set>
        where id = #{id}
    </update>
    <!--    查询班级学生人数-->
    <select id="getStudentCount" resultType="int">
        select count(*)
        from student
        where clazz_id = #{id}
    </select>
    <!--    删除班级-->
    <delete id="delete">
        delete
        from clazz
        where id = #{id}
    </delete>
</mapper>