# ==============================
# 1. 项目编译输出目录（必加）
# ==============================
/target/
/bin/
/build/
/out/

# ==============================
# 2. IDE 配置文件（每个人电脑不同，不上传）
# ==============================
### IDEA ###
.idea/
*.iws
*.iml
*.ipr

### Eclipse ###
.classpath
.project
.settings/

# ==============================
# 3. 构建工具缓存（Maven/Gradle）
# ==============================
.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/application.yml
!**/src/main/**/application.properties

### Gradle ###
.gradle
!gradle/wrapper/gradle-wrapper.jar

# ==============================
# 4. 日志文件（自动生成，不上传）
# ==============================
logs/
*.log
*.log.*

# ==============================
# 5. 系统/临时文件
# ==============================
.DS_Store
Thumbs.db
*.tmp
*.temp

# ==============================
# 6. 敏感配置文件（核心！不能上传密码）
# ==============================
# 本地私有配置（数据库密码、密钥等，自己本地用，绝不提交Git）
/application.yml
/application.properties
/bootstrap.yml
/bootstrap.properties

# 如果你把配置放在 config 文件夹
/config/

# ==============================
# 7. 其他
# ==============================
*.jar
*.war
*.ear
*.so